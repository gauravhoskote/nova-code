{
  "name": "novacode",
  "displayName": "Nova Code",
  "description": "AI coding assistant powered by Amazon Bedrock Nova models",
  "version": "0.1.0",
  "publisher": "novacode",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["AI", "Chat"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "novacode.openChat",
        "title": "Nova Code: Open Chat"
      },
      {
        "command": "novacode.configure",
        "title": "Nova Code: Configure (Python path + AWS credentials)"
      }
    ],
    "configuration": {
      "title": "Nova Code",
      "properties": {
        "novacode.pythonPath": {
          "type": "string",
          "default": "python3",
          "description": "Path to the Python interpreter that has novacode installed (e.g. /path/to/venv/bin/python3)."
        },
        "novacode.model": {
          "type": "string",
          "default": "",
          "description": "Bedrock model ID override. Leave blank to use the NOVA_MODEL env var or the package default."
        }
      }
    },
    "keybindings": [
      {
        "command": "novacode.openChat",
        "key": "ctrl+shift+n",
        "mac": "cmd+shift+n"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -p . --watch",
    "package": "vsce package"
  },
  "dependencies": {
    "marked": "^9.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
